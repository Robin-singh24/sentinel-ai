# Sentinel AI — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# Never commit the .env file to source control.

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Sentinel AI"
APP_VERSION="0.1.0"
ENVIRONMENT="development"
DEBUG=false

# ── Server ────────────────────────────────────────────────────────────────────
HOST="0.0.0.0"
PORT=8000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL="INFO"

# ── PostgreSQL — individual credentials ───────────────────────────────────────
# Supplied as separate variables so Docker Compose / Kubernetes can inject
# each credential from its own secret. The async DSN is assembled internally.
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_DB="sentinel"
POSTGRES_USER="sentinel"
POSTGRES_PASSWORD="sentinel"

# ── Database connection pool ──────────────────────────────────────────────────
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL="http://localhost:6333"

# ── LLM Provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER="groq"
LLM_MODEL="llama-3.1-8b-instant"
GROQ_API_KEY=""

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=""
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
